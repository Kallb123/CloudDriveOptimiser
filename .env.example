# ─────────────────────────────────────────────────────────────
#  CloudDriveOptimiser — Environment variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 credentials ──────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── URLs ──────────────────────────────────────────────────────
# Public URL of the backend (used to construct the OAuth redirect URI)
BACKEND_URL=http://localhost:3000
# Public URL of the frontend (used for CORS and post-login redirects)
FRONTEND_URL=http://localhost:80

# ── Session ───────────────────────────────────────────────────
# Random string used to sign session cookies — change this!
SESSION_SECRET=replace-with-a-long-random-secret

# ── Port (Docker Compose) ─────────────────────────────────────
# Host port that the frontend nginx container will be bound to
FRONTEND_PORT=80

# ── Drive analysis ────────────────────────────────────────────
# Maximum number of files to retrieve per analysis
MAX_FILES=200

# ── Video transcoding ─────────────────────────────────────────
# Target vertical resolution for optimised videos (e.g. 720 = 720p)
TRANSCODE_HEIGHT=720
# FFmpeg CRF quality value (lower = better quality, larger file; 18–28 is typical)
TRANSCODE_CRF=28
# FFmpeg encoding preset (ultrafast / superfast / veryfast / faster / fast / medium / slow / slower / veryslow)
TRANSCODE_PRESET=medium
